NODE_ENV=development
REDIS_URL=redis://localhost:6379
API_URL=http://localhost:4000
AI_SERVICE_URL=http://localhost:8000
DATABASE_URL=postgresql://aismos:aismos@localhost:5432/aismos?schema=public

# Worker concurrency
WORKER_PUBLISH_CONCURRENCY=3
WORKER_TREND_CONCURRENCY=1
WORKER_ANALYTICS_CONCURRENCY=1

# Schedules (ms)
PUBLISH_INTERVAL_MS=60000
TREND_INGESTION_INTERVAL_MS=300000
ANALYTICS_SYNC_INTERVAL_MS=600000
TOKEN_REFRESH_INTERVAL_MS=43200000
